# Creating a class
class Student:
    # Constructor
    def __init__(self, name, age):
        self.name = name
        self.age = age

    # Method
    def introduce(self):
        print(f"Hi, my name is {self.name} and I am {self.age} years old.")

# Creating objects
student1 = Student("Radhe", 18)
student2 = Student("Rahul", 19)

# Calling methods
student1.introduce()
student2.introduce()
